{
  "manifest_version": 3,
  "name": "Deras Download Manager Extension",
  "version": "1.0",
  "description": "Companion extension for Deras Download Manager to intercept browser downloads.",
  "permissions": [
    "downloads",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Deras Companion"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
